# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Force these to LF always
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf

# Binary files — no processing
*.png binary
*.jpg binary
*.gif binary
*.ico binary
