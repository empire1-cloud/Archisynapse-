{\n  "name": "archisynapse\",\n  "version\": \"1.0.0\",\n  \"description\": \"Real-time payment infrastructure for the modern web\",\n  "main\": \"src/index.js\",\n  \"scripts\": {\n    \"start\": \"node src/index.js\",\n    \"dev\": \"nodemon src/index.js\",\n    \"test\": \"jest --coverage\",\n    \"test:watch\": \"jest --watch\",\n    \"lint\": \"eslint src/**/*.js\",\n    \"lint:fix\": \"eslint src/**/*.js --fix\",\n    \"migrate\": \"knex migrate:latest\",\n    \"migrate:rollback\": \"knex migrate:rollback\",\n    \"seed\": \"knex seed:run\",\n    \"build\": \"tsc\",\n    \"docker:build\": \"docker build -t archisynapse-api:latest .\",\n    \"docker:run\": \"docker run -p 3000:3000 archisynapse-api:latest\"\n  },\n  \"keywords\": [\n    \"payments\",\n    \"fintech\",\n    \"api\",\n    \"real-time\",\n    \"settlement\"\n  ],\n  \"author\": \"Archisynapse Team\",\n  \"license\": \"MIT\",\n  \"dependencies\": {\n    \"express\": \"^4.18.2\",\n    \"dotenv\": \"^16.0.3\",\n    \"pg\": \"^8.8.0\",\n    \"redis\": \"^4.5.1\",\n    \"jsonwebtoken\": \"^9.0.0\",\n    \"bcryptjs\": \"^2.4.3\",\n    \"axios\": \"^1.3.4\",\n    \"joi\": \"^17.9.1\",\n    \"helmet\": \"^7.0.0\",\n    \"cors\": \"^2.8.5\",\n    \"winston\": \"^3.8.2\",\n    \"pino\": \"^13.2.0\",\n    \"express-rate-limit\": \"^6.7.0\",\n    \"amqplib\": \"^0.10.3\",\n    \"uuid\": \"^9.0.0\"\n  },\n  \"devDependencies\": {\n    \"nodemon\": \"^2.0.20\",\n    \"jest\": \"^29.5.0\",\n    \"supertest\": \"^6.3.3\",\n    \"eslint\": \"^8.36.0\",\n    \"prettier\": \"^2.8.4\",\n    \"@types/node\": \"^18.15.11\",\n    \"typescript\": \"^5.0.2\"\n  },\n  \"engines\": {\n    \"node\": \">=16.0.0\",\n    \"npm\": \">=8.0.0\"\n  }\n}\n