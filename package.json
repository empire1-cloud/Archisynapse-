{
  "name": "archisynapse",
  "version": "1.0.0",
  "description": "Real-time payment infrastructure for the modern web",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "NODE_ENV=test jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "build": "tsc",
    "demo": "node demo.js",
    "docker:build": "docker build -t archisynapse-api:latest .",
    "docker:run": "docker run -p 3000:3000 archisynapse-api:latest"
  },
  "keywords": [
    "payments",
    "fintech",
    "api",
    "real-time",
    "settlement"
  ],
  "author": "Archisynapse Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "pg": "^8.8.0",
    "redis": "^4.5.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "axios": "^1.3.4",
    "joi": "^17.9.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "winston": "^3.8.2",
    "pino": "^10.3.1",
    "express-rate-limit": "^6.7.0",
    "amqplib": "^0.10.3",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.36.0",
    "prettier": "^2.8.4",
    "@types/node": "^18.15.11",
    "typescript": "^5.0.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
