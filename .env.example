# Environment variables\n# Copy this file to .env.local and update values\n\n# Application\nNODE_ENV=development\nAPI_PORT=3000\nAPI_HOST=0.0.0.0\n\n# Database\nDATABASE_URL=postgresql://archisynapse:secure_password@localhost:5432/archisynapse\nDATABASE_POOL_SIZE=20\nDATABASE_STATEMENT_TIMEOUT=30000\n\n# Redis\nREDIS_URL=redis://localhost:6379\nREDIS_PASSWORD=\nREDIS_POOL_SIZE=10\n\n# Message Queue\nRABBITMQ_URL=amqp://guest:guest@localhost:5672\nKAFKA_BROKERS=localhost:9092\n\n# Security\nJWT_SECRET=your_jwt_secret_here_change_in_production\nJWT_EXPIRY=24h\nAPI_KEY_SECRET=your_api_key_secret_here_change_in_production\nENCRYPTION_KEY=your_encryption_key_here_32_chars_minimum_change_in_production\n\n# Logging\nLOG_LEVEL=debug\nLOG_FORMAT=json\n\n# Fraud Detection\nML_MODEL_PATH=./models/fraud_detection.pkl\nML_MODEL_VERSION=1.0.0\nFRAUD_THRESHOLD=0.7\n\n# Rate Limiting\nRATE_LIMIT_WINDOW_MS=60000\nRATE_LIMIT_MAX_REQUESTS=1000\n\n# CORS\nCORS_ORIGIN=http://localhost:3001,http://localhost:3000\nCORS_CREDENTIALS=true\n\n# Payment Processing\nSTRIPE_API_KEY=sk_test_change_me\nSTRIPE_WEBHOOK_SECRET=whsec_change_me\n\n# AWS (for S3 backups)\nAWS_REGION=us-east-1\nAWS_ACCESS_KEY_ID=change_me\nAWS_SECRET_ACCESS_KEY=change_me\nS3_BUCKET=archisynapse-backups\n\n# Email Service\nSMTP_HOST=smtp.gmail.com\nSMTP_PORT=587\nSMTP_USER=change_me@gmail.com\nSMTP_PASS=change_me\nSMTP_FROM=noreply@archisynapse.io\n\n# Analytics\nMIXPANEL_TOKEN=change_me\nSEGMENT_WRITE_KEY=change_me\n